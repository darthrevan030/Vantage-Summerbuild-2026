# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key: Settings → API in the Supabase dashboard.
# The anon key is safe to expose client-side (RLS enforces access).
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key: Settings → API → service_role. NEVER expose client-side.
# Used server-side only for auth.admin.listUsers() in the admin dashboard.
SUPABASE_ADMIN_KEY=<your-service-role-key>

# ── Financial data APIs ──────────────────────────────────────────────────────

# Finnhub — https://finnhub.io (free tier available)
# Used for:
#   • Equity sparklines: 30-day daily closes via /stock/candle
#   • FX Lab sparklines: 30-day OANDA forex candles via /forex/candle
# Without this key: sparkline charts are empty for equities and FX cards.
FINNHUB_API_KEY=<your-finnhub-key>

# EODHD — https://eodhd.com (paid, ~$20/mo for real-time)
# Used for:
#   • Live equity/ETF/REIT prices on price refresh, across global exchanges:
#     US (NYSE/NASDAQ), LSE (London), TSE (Tokyo), HKEX (Hong Kong),
#     NSE/BSE (India), SGX (Singapore), ASX (Australia), XETRA (Germany),
#     SSE/SZSE (Shanghai/Shenzhen), Euronext Paris/Milan, and more.
#   Ticker format: SYMBOL.EXCHANGE (e.g. VWRA.LSE, 7203.TSE, RELIANCE.NSE)
#   The Add Holdings form lets users select the exchange — it's appended automatically.
# Without this key: equity prices stay at whatever was last manually entered.
# Crypto prices still update via CoinGecko (no key needed).
EODHD_API_KEY=<your-eodhd-key>

# GoldAPI — https://www.goldapi.io (free tier: 100 req/mo)
# Used for:
#   • Live XAU/USD spot price on price refresh for GOLD/XAU/GLD tickers
# Without this key: gold holdings keep their manually entered price.
GOLDAPI_KEY=<your-goldapi-key>

# other news headlines apis
ALPHA_VANTAGE_KEY=<your-alpha-vantage-key>
NEWS_API_KEY=<news-api-key>

# No key needed (used automatically):
#   • CoinGecko — live crypto prices (BTC, ETH, SOL, etc.) + 30-day sparklines
#   • Frankfurter — live FX rates for all currency conversions (base: SGD)

# ── AI ───────────────────────────────────────────────────────────────────────
# Anthropic — https://console.anthropic.com
# Used for: the Analysis tab AI commentary (streaming claude-haiku-4-5).
ANTHROPIC_API_KEY=sk-ant-api03-<your-anthropic-key>
